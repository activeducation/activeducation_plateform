# =============================================================================
# ActivEducation Backend - Variables d'Environnement
# =============================================================================
# Copiez ce fichier vers .env et remplissez les valeurs
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONNEMENT
# -----------------------------------------------------------------------------
# Options: development, staging, production
ENVIRONMENT=development

# Mode debug (doit etre False en production)
DEBUG=True

# -----------------------------------------------------------------------------
# SUPABASE (OBLIGATOIRE)
# -----------------------------------------------------------------------------
# URL de votre projet Supabase (Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Cle anonyme (anon key) - pour operations publiques
SUPABASE_KEY=your-anon-key-here

# Cle service role - pour operations admin backend (CONFIDENTIEL !)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret Supabase pour validation locale des tokens (RECOMMANDE en prod)
# Recuperer dans : Supabase Dashboard → Settings → API → JWT Secret
# Si absent, le backend appelera l'API Supabase pour valider chaque token (plus lent)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Liste des origines autorisees, separees par des virgules
# ATTENTION: Ne jamais utiliser "*" en production
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# -----------------------------------------------------------------------------
# REDIS CACHE (optionnel - fallback vers cache memoire si absent)
# -----------------------------------------------------------------------------
# En production (Docker): redis://redis:6379/0
# En developpement local: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Nombre maximum de requetes par minute par IP
RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# CHAT IA - AIDA (Groq)
# -----------------------------------------------------------------------------
# Cle API Groq - GRATUIT sur https://console.groq.com
# Modele: llama-3.1-8b-instant (rapide, multilingue)
# Quota gratuit: 14 400 requetes/jour, 30 req/min
GROQ_API_KEY=your-groq-api-key-here

# Provider fallback : Ollama (local, gratuit, aucune cle requise)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# -----------------------------------------------------------------------------
# MONITORING - Sentry (optionnel mais recommande en production)
# -----------------------------------------------------------------------------
# DSN Sentry pour error tracking
# Obtenir sur https://sentry.io (plan gratuit: 5000 events/mois)
# Laisser vide pour desactiver
SENTRY_DSN=

# Base de donnees Supabase (pour Alembic migrations)
# Trouver dans: Supabase Dashboard -> Settings -> Database -> Connection string
SUPABASE_DB_HOST=db.PROJECT.supabase.co
SUPABASE_DB_PASSWORD=your-db-password
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Niveau de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
