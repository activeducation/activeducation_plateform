# =============================================================================
# ActivEducation Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS commiter .env dans git
# =============================================================================

# Environment (development | staging | production)
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# Supabase (obligatoire)
# =============================================================================
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# =============================================================================
# SECRET_KEY : signe les tokens JWT internes (reset password, sessions internes)
# Generer avec : python -c "import secrets; print(secrets.token_urlsafe(48))"
# Exemple de format attendu : "xK9mP2vR7qW4nJ6hT1aF8sL3dG0bY5cZ..."  (64 caracteres)
# NE PAS utiliser de JWT comme cle secrete !
# =============================================================================
SECRET_KEY=change-me-to-a-random-64-char-string-generated-with-secrets-token-urlsafe

# =============================================================================
# Redis (optionnel — fallback memoire si absent)
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# LLM — AIDA (cle Groq gratuite : https://console.groq.com)
# =============================================================================
GROQ_API_KEY=<groq-api-key>

# =============================================================================
# CORS (separer par virgule)
# =============================================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# Monitoring (optionnel)
# =============================================================================
SENTRY_DSN=

LOG_LEVEL=INFO
