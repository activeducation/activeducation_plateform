{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "test",
        "chore",
        "perf",
        "security",
        "ci",
        "revert"
      ]
    ],
    "scope-enum": [
      1,
      "always",
      [
        "backend",
        "app",
        "admin",
        "infra",
        "ci",
        "docs",
        "deps"
      ]
    ],
    "subject-max-length": [2, "always", 100],
    "subject-min-length": [2, "always", 5],
    "subject-case": [2, "always", "lower-case"],
    "header-max-length": [2, "always", 120]
  }
}
